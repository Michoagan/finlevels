# Supabase public client configuration
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-side service role key
# Server-only. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Challenge token encryption secret
# Server-only. Use a long random value in production.
CHALLENGE_TOKEN_SECRET=

# Resend email sending
# Server-only.
RESEND_API_KEY=

# Optional but recommended. Must be a verified Resend sender/domain in production.
# Example: FinLevels <hello@finlevels.app>
RESEND_FROM_EMAIL=

# Public site URL used to generate email links.
# Local example: http://localhost:3000
# Production example: https://finlevels.app
SITE_URL=http://localhost:3000

# Feature flag for automated challenge email sending.
# Keep false/empty to deploy safely without sending emails.
# Set to true only when you are ready for the cron to send emails.
CHALLENGE_EMAIL_CRON_ENABLED=false

# Secret used to protect cron endpoint manual calls.
# Server-only. Send as either:
# Authorization: Bearer your-secret
# or x-cron-secret: your-secret
CRON_SECRET=

# Google reCAPTCHA v3 configuration
# Public site key (safe to expose to browser)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Private secret key (server-side only)
RECAPTCHA_SECRET_KEY=

# Gemini AI (Google) API key for transaction analysis
# Server-only. Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Plaid API credentials
# Server-only. Get from https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox | development | production
PLAID_ENV=sandbox

# VAPID keys for Web Push Notifications
# Generate once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose to browser.
# VAPID_PRIVATE_KEY is server-only. Never prefix with NEXT_PUBLIC_.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# PostHog analytics
# Public — safe to expose to browser.
# Get from: PostHog → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# PostHog ingestion host. Use one of:
#   https://us.i.posthog.com  (US Cloud)
#   https://eu.i.posthog.com  (EU Cloud)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
